@startuml

    !include lexakai.theme
    
    title "com.telenav.kivakit.configuration.lookup"
    
    class InstanceIdentifier
    {
        --(constructors)--
        +InstanceIdentifier(Class<?>)
        +InstanceIdentifier(Enum<?>)
        +InstanceIdentifier(String)
    }
    
    Registry --> InstanceIdentifier : "locates instances with"
    class Registry
    {
        --
        +Registry global()
        +Registry of(Object)
        --(lookup)--
        +T lookup(Class<T> type, Enum<?> instance)
        +T lookup(Class<T> type)
        +T lookup(Class<T> type, InstanceIdentifier)
        +T lookup(Class<T> type, String instance)
        +T register(T singleton)
        +void register(Object, Enum<?> instance)
        +void register(Object, InstanceIdentifier)
        +void register(Object, String instance)
    }
    
@enduml

